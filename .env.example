# Live Harness v1.5 — AI Sandbox Configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# Provider: "gemini", "openai", or "openai_compatible"
HARNESS_AI_PROVIDER=gemini

# Base URL (required for openai_compatible, ignored for gemini/openai)
# Example: https://openprovider.mimika.in/v1
# HARNESS_AI_BASE_URL=

# Model name (provider-specific)
# Gemini: gemini-2.0-flash, gemini-2.0-flash-lite, etc.
# OpenAI: gpt-4o-mini, gpt-3.5-turbo, etc.
# OpenProvider: openprovider/auto-free, atxp/gpt-5.5, etc.
HARNESS_AI_MODEL=gemini-2.0-flash

# API key (never committed, never shown in UI)
# OpenProvider requires an OpenProvider API key here.
# ATXP_CONNECTION is only a provider connection string for OpenProvider-side sync;
# it is not accepted as HARNESS_AI_API_KEY by /v1/chat/completions.
HARNESS_AI_API_KEY=

# Optional provider connection string for local notes/config parity only.
# The harness does not send this to the browser or to OpenProvider.
# ATXP_CONNECTION=
