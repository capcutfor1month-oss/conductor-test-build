# ─────────────────────────────────────────────────────────────
#  Conductor — Environment Variables
#
#  HOW TO USE:
#  1. Copy this file and rename it to  .env  (remove .template)
#  2. Fill in your API keys below
#  3. Never share your .env file — it contains private keys
# ─────────────────────────────────────────────────────────────

# Google API Key — needed for Conductor's memory system (Mem0)
# Get yours free at: https://aistudio.google.com/apikey
# Free tier is enough. Enable billing only if you hit rate limits.
GOOGLE_API_KEY=your_google_api_key_here
